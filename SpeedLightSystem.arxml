            </R-PORT-PROTOTYPE>
          </PORTS>
          <INTERNAL-BEHAVIORS>
            <SWC-INTERNAL-BEHAVIOR>
              <SHORT-NAME>LedActuatorInternalBehaviour</SHORT-NAME>
              <RUNNABLES>
                <RUNNABLE-ENTITY>
                  <SHORT-NAME>ControlSignalRE</SHORT-NAME>
                  <DATA-READ-ACCESSS>
                    <VARIABLE-ACCESS>
                      <ACCESSED-VARIABLE>
                        <LOCAL-VARIABLE-REF DEST="VARIABLE-DATA-PROTOTYPE">/ARRoot/SpeedSRInterface_Vechicle/VechicleSpeed</LOCAL-VARIABLE-REF>
