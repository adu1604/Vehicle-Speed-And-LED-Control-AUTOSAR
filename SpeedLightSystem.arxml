            </ASSEMBLY-SW-CONNECTOR>
            <ASSEMBLY-SW-CONNECTOR>
              <SHORT-NAME>Conn_Vehicle_to_LedActuator</SHORT-NAME>
              <PROVIDER-IREF S="">
                <CONTEXT-COMPONENT-REF DEST="SW-COMPONENT-PROTOTYPE">/ARRoot/SpeedComposition/VechicleSpeedSwComponentPrototype</CONTEXT-COMPONENT-REF>
                <TARGET-P-PORT-REF DEST="P-PORT-PROTOTYPE">/ARRoot/VechicleSpeedASWC/VechicleSpeedPPort</TARGET-P-PORT-REF>
