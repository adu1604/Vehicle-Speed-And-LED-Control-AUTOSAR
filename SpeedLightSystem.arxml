                <TARGET-R-PORT-REF DEST="R-PORT-PROTOTYPE">/ARRoot/VechicleSpeedASWC/WheelSpeedRPort</TARGET-R-PORT-REF>
              </REQUESTER-IREF>
            </ASSEMBLY-SW-CONNECTOR>
          </CONNECTORS>
        </COMPOSITION-SW-COMPONENT-TYPE>
        <SENDER-RECEIVER-INTERFACE>
          <SHORT-NAME>SpeedSRInterface_Led</SHORT-NAME>
          <DATA-ELEMENTS>
            <VARIABLE-DATA-PROTOTYPE>
              <SHORT-NAME>LedSignal</SHORT-NAME>
