                <TARGET-R-PORT-REF DEST="R-PORT-PROTOTYPE">/ARRoot/LedControlASWC/LedSignalRPort</TARGET-R-PORT-REF>
              </REQUESTER-IREF>
            </ASSEMBLY-SW-CONNECTOR>
            <ASSEMBLY-SW-CONNECTOR>
              <SHORT-NAME>Conn_Vehicle_to_LED</SHORT-NAME>
