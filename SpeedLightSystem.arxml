                <RUNNABLE-ENTITY>
                  <SHORT-NAME>ControlLedRE</SHORT-NAME>
                  <DATA-READ-ACCESSS>
                    <VARIABLE-ACCESS>
                      <ACCESSED-VARIABLE>
                        <LOCAL-VARIABLE-REF DEST="VARIABLE-DATA-PROTOTYPE">/ARRoot/SpeedSRInterface_Vechicle/VechicleSpeed</LOCAL-VARIABLE-REF>
