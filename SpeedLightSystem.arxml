          <COMPONENTS>
            <SW-COMPONENT-PROTOTYPE>
              <SHORT-NAME>LedActuatorComponentPrototype</SHORT-NAME>
              <TYPE-TREF DEST="SENSOR-ACTUATOR-SW-COMPONENT-TYPE">/ARRoot/LedActuatorSWC</TYPE-TREF>
            </SW-COMPONENT-PROTOTYPE>
            <SW-COMPONENT-PROTOTYPE S="">
